[Unit]
Description=Taiko Auto Sync Upload Panel
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/taiko-update2
Environment="PATH=/opt/taiko-update2/.venv/bin"
ExecStart=/opt/taiko-update2/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
